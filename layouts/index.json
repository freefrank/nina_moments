{{- $pages := where site.RegularPages "Type" "in" site.Params.mainSections -}}
{{- $pages = where $pages "Params.hiddenInHomeList" "!=" "true" -}}
{
  "posts": [
    {{- range $index, $page := $pages -}}
    {{- if $index }},{{ end }}
    {
      "title": {{ $page.Title | jsonify }},
      "url": {{ $page.Permalink | jsonify }},
      "date": {{ $page.Date.Format "2006-01-02" | jsonify }},
      "year": {{ $page.Date.Format "2006" | jsonify }},
      "month": {{ $page.Date.Format "01" | jsonify }},
      "monthName": {{ $page.Date.Format "01月" | jsonify }},
      {{- /* 摘要 = 正文 + 链接标题/摘要（保证链接内容可被搜索） */ -}}
      {{- $s := $page.Content | plainify | htmlUnescape | truncate 300 -}}
      {{- with $page.Params.link -}}
        {{- $s = printf "%s %s %s" $s (.title | default "") (.summary | default "") | strings.TrimSpace -}}
      {{- end -}}
      "summary": {{ $s | truncate 500 | jsonify }},
      "dateFormatted": {{ $page.Date.Format "January 2, 2006" | jsonify }},
      {{- $firstImage := "" -}}
      {{- with $page.Params.images -}}{{- $firstImage = index . 0 -}}{{- end -}}
      "firstImage": {{ $firstImage | jsonify }}
    }
    {{- end -}}
  ]
}
